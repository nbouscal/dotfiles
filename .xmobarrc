Config { font = "-misc-fixed-*-*-*-*-13-*-*-*-*-*-*-*"
       , borderColor = "black"
       , border = TopB
       , bgColor = "black"
       , fgColor = "grey"
       , position = Top
       , lowerOnStart = True
       , hideOnStart = False
       , persistent = False
       , commands = [ Run Weather "KGEG" ["-t","<tempC>C","-L","18","-H","25","--normal","green","--high","red","--low","lightblue"] 36000
                    , Run Wireless "wlan0" ["-L","50","-H","75","-l","red","-n","yellow","-h","green"] 10
                    , Run Battery ["-t","Bat: <acstatus><left>% / <timeleft>","-L","25","-H","75","-l","red","-h","green","--","-O","<fc=green>+</fc>","-o",""] 10
                    , Run Cpu ["-L","3","-H","50","--normal","green","--high","red"] 10
                    , Run Memory ["-t","Mem: <usedratio>%"] 10
                    , Run Volume "default" "Master" ["-t","Vol: <volume>%"] 10
                    , Run Com "uname" ["-s","-r"] "" 36000
                    , Run Date "%a %b %_d %Y %H:%M:%S" "date" 10
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = "%cpu% | %memory% | %battery% | %wlan0wi% | %default:Master%  }{ <fc=#ee9a00>%date%</fc>| %KGEG% | %uname%"
       }
