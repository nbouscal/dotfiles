. ~/dotfiles/.zsh/git_aliases
. ~/dotfiles/.zsh/aliases
. ~/dotfiles/.zsh/functions

HISTFILE=~/.zsh/history
HISTSIZE=10000
SAVEHIST=1000000
setopt autocd notify
bindkey -v

zstyle :compinstall filename '/home/nathan/.zshrc'

fpath=(/usr/local/share/zsh-completions $fpath)

autoload -Uz compinit
compinit

unsetopt correct_all
setopt correct

source ~/.antigen/antigen.zsh
antigen-use oh-my-zsh
antigen-bundle zsh-users/zsh-syntax-highlighting
antigen-theme nathan
antigen-apply

PATH="/Users/nathan/.cabal-sandbox/bin:/Users/nathan/Library/Haskell/bin:/Users/nathan/bin:$PATH"

bindkey '\e[A' history-search-backward
bindkey '\e[B' history-search-forward

# 256color for tmux
[ -n "$TMUX" ] && export TERM=screen-256color
export URBIT_HOME=/Users/nathan/urbit/urb

HASKELL_CODE_DIR=~/soostone
SOOSTONE_CODE_DIR=~/soostone
