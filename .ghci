:set prompt      "\SOH\ESC[35;1m\STXλ>\SOH\ESC[0m\STX "
:set prompt-cont "\SOH\ESC[35;1m\STX |\SOH\ESC[0m\STX "

:def hoogle \str -> return $ ":! hoogle search --color "        ++ show str
:def doc    \str -> return $ ":! hoogle search --color --info " ++ show str

:def pointfree \str -> return $ ":! pointfree " ++ show str
:def pointful  \str -> return $ ":! pointful "  ++ show str

:set +m
:set -Wwarn
